<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <div><h1 class="page-title">Manage Users</h1><p class="page-subtitle">All registered users on the platform</p></div>
      </div>
      <!-- Filters -->
      <div class="filter-bar">
        <form action="/admin/users" method="GET" class="filter-form">
          <input type="text" name="search" placeholder="Search by name or email..." class="filter-input" value="<%= filters.search || '' %>">
          <select name="role" class="filter-select">
            <option value="">All Roles</option>
            <option value="client" <%= filters.role === 'client' ? 'selected' : '' %>>Client</option>
            <option value="freelancer" <%= filters.role === 'freelancer' ? 'selected' : '' %>>Freelancer</option>
          </select>
          <select name="status" class="filter-select">
            <option value="">All Status</option>
            <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="banned" <%= filters.status === 'banned' ? 'selected' : '' %>>Banned</option>
          </select>
          <select name="sort" class="filter-select">
            <option value="-createdAt" <%= filters.sort === '-createdAt' ? 'selected' : '' %>>Newest First</option>
            <option value="createdAt" <%= filters.sort === 'createdAt' ? 'selected' : '' %>>Oldest First</option>
            <option value="-rating" <%= filters.sort === '-rating' ? 'selected' : '' %>>Top Rated</option>
          </select>
          <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Filter</button>
          <a href="/admin/users" class="btn btn-outline">Clear</a>
        </form>
      </div>
      <div class="table-card">
        <div class="table-header">
          <h3>Users (<%= users.length %>)</h3>
        </div>
        <table class="data-table">
          <thead>
            <tr><th>User</th><th>Role</th><th>Email</th><th>Joined</th><th>Projects</th><th>Status</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
            <tr>
              <td>
                <div class="user-cell">
                  <img src="<%= u.googleAvatar || '/avatar/' + u._id %>" class="table-avatar" onerror="this.src='/images/default-avatar.png'">
                  <div>
                    <div class="fw-bold"><%= u.name %></div>
                    <div class="text-muted small"><%= u.location || '' %></div>
                  </div>
                </div>
              </td>
              <td><span class="badge role-<%= u.role %>"><%= u.role %></span></td>
              <td class="text-muted"><%= u.email %></td>
              <td><%= new Date(u.createdAt).toLocaleDateString('en-IN') %></td>
              <td><%= u.completedProjects || 0 %> done</td>
              <td>
                <% if (u.isBanned) { %><span class="badge badge-danger">Banned</span>
                <% } else if (u.isVerified) { %><span class="badge badge-success">Active</span>
                <% } else { %><span class="badge badge-warning">Unverified</span><% } %>
              </td>
              <td>
                <div class="action-btns">
                  <a href="/profile/<%= u._id %>" class="btn btn-sm btn-outline" title="View Profile"><i class="fas fa-eye"></i></a>
                  <form action="/admin/users/<%= u._id %>/ban" method="POST" style="display:inline">
                    <button type="submit" class="btn btn-sm <%= u.isBanned ? 'btn-success' : 'btn-warning' %>" 
                      onclick="return confirm('<%= u.isBanned ? 'Unban' : 'Ban' %> this user?')"
                      title="<%= u.isBanned ? 'Unban' : 'Ban' %>">
                      <i class="fas <%= u.isBanned ? 'fa-unlock' : 'fa-ban' %>"></i>
                    </button>
                  </form>
                  <form action="/admin/users/<%= u._id %>/delete" method="POST" style="display:inline">
                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this user permanently?')" title="Delete">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
            <% if (users.length === 0) { %>
              <tr><td colspan="7" class="empty-state">Users Not found</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
  <script src="/js/main.js"></script>
  <script src="/js/notifications.js"></script>
  <script src="/js/theme.js"></script>
  <script>const USER_ID = '<%= currentUser._id %>';</script>
</body>
</html>