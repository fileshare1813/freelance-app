<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/theme.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="/socket.io/socket.io.js"></script>
  <style>
    /* ── Cron box — theme variables use karo ── */
    .cron-box {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 18px 22px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .cron-box h4 {
      font-size: .95rem;
      font-weight: 700;
      margin-bottom: 3px;
      color: var(--text-primary);
    }
    .cron-box p {
      font-size: .82rem;
      color: var(--text-muted);
      margin: 0;
    }

    /* ── Legend ── */
    .legend {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 14px;
      font-size: .8rem;
      color: var(--text-secondary);
    }
    .legend-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 5px;
      vertical-align: middle;
    }

    /* ── Table row urgency — dark mode aware ── */
    .row-critical td {
      background: rgba(239, 68, 68, 0.08) !important;
    }
    .row-warned td {
      background: rgba(245, 158, 11, 0.08) !important;
    }
    .row-safe td {
      background: rgba(34, 197, 94, 0.08) !important;
    }

    /* ── Hour badges — dark mode aware ── */
    .hbadge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 700;
    }
    /* Light mode */
    .hb-red    { background: #fee2e2; color: #dc2626; }
    .hb-orange { background: #fef3c7; color: #d97706; }
    .hb-green  { background: #dcfce7; color: #16a34a; }
    .hb-gray   { background: #f1f5f9; color: #64748b; }

    /* Dark mode overrides */
    [data-theme="dark"] .hb-red    { background: #7f1d1d; color: #fca5a5; }
    [data-theme="dark"] .hb-orange { background: #78350f; color: #fcd34d; }
    [data-theme="dark"] .hb-green  { background: #14532d; color: #86efac; }
    [data-theme="dark"] .hb-gray   { background: #252540; color: #94a3b8; }

    /* ── Warning badge dark mode ── */
    [data-theme="dark"] .badge-warning {
      background: #78350f !important;
      color: #fcd34d !important;
    }
    [data-theme="dark"] .badge-success {
      background: #14532d !important;
      color: #86efac !important;
    }

    /* ── Empty state ── */
    .empty-clear {
      text-align: center;
      padding: 48px 20px;
      color: var(--text-muted);
    }
    .empty-clear i {
      font-size: 3rem;
      color: var(--success);
      display: block;
      margin-bottom: 12px;
    }
    .empty-clear h3 {
      color: var(--success);
      margin-bottom: 6px;
    }

    /* ── Stat card — 4th one (no color var) ── */
    .stat-card-neutral {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      position: relative;
      overflow: hidden;
    }
    .stat-card-neutral::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 4px;
      background: #ef4444;
    }
    .stat-card-neutral .stat-icon { color: #ef4444; font-size: 1.5rem; }
    .stat-card-neutral .stat-value { font-size: 1.8rem; font-weight: 800; color: var(--text-primary); }
    .stat-card-neutral .stat-label { font-size: 0.85rem; color: var(--text-muted); }
  </style>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">

      <div class="page-header">
        <div>
          <h1 class="page-title">Unverified Users</h1>
          <p class="page-subtitle">Warning &amp; auto-ban tracker</p>
        </div>
        <a href="/admin/users" class="btn btn-outline">
          <i class="fas fa-arrow-left"></i> Back to Users
        </a>
      </div>

      <!-- Cron trigger -->
      <div class="cron-box">
        <div>
          <h4>
            <i class="fas fa-clock" style="color:var(--primary);margin-right:6px;"></i>
            Verification Cron Job
          </h4>
          <p>It will run automatically every day at midnight (Eastern Time). You can also trigger it manually for testing purposes.</p>
        </div>
        <form action="/admin/run-verification-cron" method="POST">
          <button type="submit" class="btn btn-warning"
            onclick="return confirm('Cron abhi run karein?\nWarning emails bhejenge aur eligible users ban honge!')">
            <i class="fas fa-play"></i> Run Now
          </button>
        </form>
      </div>

      <!-- Legend -->
      <div class="legend">
        <span><span class="legend-dot" style="background:#ef4444;"></span>It is about to be banned. (&lt;6 hrs)</span>
        <span><span class="legend-dot" style="background:#f59e0b;"></span>Warning Sent</span>
        <span><span class="legend-dot" style="background:#22c55e;"></span>New in 24hrs</span>
      </div>

      <!-- Stats -->
      <div class="stats-grid" style="margin-bottom:20px;">
        <div class="stat-card stat-orange">
          <div class="stat-icon"><i class="fas fa-user-clock"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= users.length %></div>
            <div class="stat-label">Total Unverified</div>
          </div>
        </div>
        <div class="stat-card stat-blue">
          <div class="stat-icon"><i class="fas fa-envelope-open-text"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= users.filter(u => u.warningSentAt).length %></div>
            <div class="stat-label">Warning Sent</div>
          </div>
        </div>
        <div class="stat-card-neutral">
          <div class="stat-icon"><i class="fas fa-ban"></i></div>
          <div class="stat-value">
            <%= users.filter(u => u.warningSentAt && u.banInHrs !== null && u.banInHrs <= 6).length %>
          </div>
          <div class="stat-label">Ban in 6hrs</div>
        </div>
        <div class="stat-card stat-green">
          <div class="stat-icon"><i class="fas fa-user-plus"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= users.filter(u => u.ageHrs < 24).length %></div>
            <div class="stat-label">New (&lt;24hrs)</div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="table-card">
        <div class="table-header">
          <h3>Unverified Users (<%= users.length %>)</h3>
        </div>

        <% if (users.length === 0) { %>
          <div class="empty-clear">
            <i class="fas fa-check-circle"></i>
            <h3>All clear!</h3>
            <p>No unverified user.</p>
          </div>
        <% } else { %>
        <div style="overflow-x:auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Role</th>
                <th>Registered</th>
                <th>Account Age</th>
                <th>Warning Status</th>
                <th>Ban In</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(u => {
                let rowClass = '';
                if (u.warningSentAt && u.banInHrs !== null && u.banInHrs <= 6) rowClass = 'row-critical';
                else if (u.warningSentAt)  rowClass = 'row-warned';
                else if (u.ageHrs < 24)    rowClass = 'row-safe';
              %>
              <tr class="<%= rowClass %>">
                <td>
                  <div class="user-cell">
                    <img src="<%= u.googleAvatar || '/avatar/' + u._id %>"
                         class="table-avatar"
                         onerror="this.src='/images/default-avatar.png'">
                    <div>
                      <div class="fw-bold"><%= u.name %></div>
                      <div class="text-muted small"><%= u.email %></div>
                    </div>
                  </div>
                </td>
                <td><span class="badge role-<%= u.role %>"><%= u.role %></span></td>
                <td class="text-muted small">
                  <%= new Date(u.createdAt).toLocaleString('en-IN', {
                    day:'2-digit', month:'short', year:'numeric',
                    hour:'2-digit', minute:'2-digit'
                  }) %>
                </td>
                <td>
                  <span class="hbadge <%= u.ageHrs >= 48 ? 'hb-red' : u.ageHrs >= 24 ? 'hb-orange' : 'hb-green' %>">
                    <%= u.ageHrs %> hrs ago
                  </span>
                </td>
                <td>
                  <% if (u.warningSentAt) { %>
                    <span class="badge badge-warning">
                      <i class="fas fa-exclamation-triangle"></i> Warning Sent
                    </span>
                    <div class="text-muted small" style="margin-top:3px;">
                      <%= new Date(u.warningSentAt).toLocaleString('en-IN', {
                        day:'2-digit', month:'short',
                        hour:'2-digit', minute:'2-digit'
                      }) %>
                    </div>
                  <% } else { %>
                    <span class="badge badge-success">
                      <i class="fas fa-clock"></i> Pending
                    </span>
                    <div class="text-muted small" style="margin-top:3px;">
                      A warning will be issued at midnight.
                    </div>
                  <% } %>
                </td>
                <td>
                  <% if (u.warningSentAt && u.banInHrs !== null) { %>
                    <% if (u.banInHrs <= 0) { %>
                      <span class="hbadge hb-red">Ban Due!</span>
                    <% } else { %>
                      <span class="hbadge <%= u.banInHrs <= 6 ? 'hb-red' : u.banInHrs <= 12 ? 'hb-orange' : 'hb-gray' %>">
                        ~<%= u.banInHrs %> hrs
                      </span>
                    <% } %>
                  <% } else { %>
                    <span class="text-muted small">—</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </main>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/notifications.js"></script>
  <script src="/js/theme.js"></script>
  <script>const USER_ID = '<%= currentUser._id %>';</script>
</body>
</html>
