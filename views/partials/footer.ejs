<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">⚡ FreelanceHub</span>
      <p class="footer-tagline">Connect. Create. Collaborate.</p>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <div class="footer-col-title">Platform</div>
        <% if (currentUser) { %>
          <% if (currentUser.role === 'client') { %>
            <a href="/client/post-project">Post a Project</a>
            <a href="/client/find-freelancer">Find Talent</a>
            <a href="/client/my-projects">My Projects</a>
          <% } else if (currentUser.role === 'freelancer') { %>
            <a href="/freelancer/browse-projects">Browse Projects</a>
            <a href="/freelancer/my-proposals">My Proposals</a>
            <a href="/freelancer/edit-profile">Edit Profile</a>
          <% } %>
        <% } else { %>
          <a href="/auth/register">Get Started</a>
          <a href="/auth/login">Login</a>
        <% } %>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Account</div>
        <% if (currentUser) { %>
          <a href="/profile">My Profile</a>
          <a href="/messages">Messages</a>
          <a href="/notifications">Notifications</a>
          <a href="/auth/logout">Logout</a>
        <% } else { %>
          <a href="/auth/register?role=client">Hire Talent</a>
          <a href="/auth/register?role=freelancer">Find Work</a>
          <a href="/auth/forgot-password">Reset Password</a>
        <% } %>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Support</div>
        <a href="mailto:support@freelancehub.com">Contact Support</a>
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Help Center</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© <%= new Date().getFullYear() %> FreelanceHub. All rights reserved.</span>
    <div class="footer-socials">
      <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
      <a href="#" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
      <a href="#" title="GitHub"><i class="fab fa-github"></i></a>
    </div>
  </div>
</footer>

