<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
      <div class="profile-hero">
        <div class="profile-hero-bg"></div>
        <div class="profile-hero-content">
          <img src="<%= profileUser.googleAvatar || '/avatar/' + profileUser._id %>"
            class="profile-hero-avatar" onerror="this.src='/images/default-avatar.png'">
          <div class="profile-hero-info">
            <h1><%= profileUser.name %></h1>
            <span class="badge role-<%= profileUser.role %> badge-lg"><%= profileUser.role %></span>
            <% if (profileUser.role === 'freelancer') { %>
              <span class="avail-badge avail-<%= profileUser.availability || 'available' %>"><%= (profileUser.availability || 'available').replace('_',' ') %></span>
            <% } %>
            <div class="rating-row rating-lg">
              <% for(let i=1;i<=5;i++) { %><i class="fas fa-star <%= i <= Math.round(profileUser.rating||0) ? 'star-filled':'star-empty' %>"></i><% } %>
              <span>(<%= profileUser.reviewCount || 0 %> reviews)</span>
            </div>
            <% if (profileUser.location) { %><p><i class="fas fa-map-marker-alt"></i> <%= profileUser.location %></p><% } %>
          </div>
          <div class="profile-hero-actions">
            <% if (currentUser && currentUser._id.toString() === profileUser._id.toString()) { %>
              <% if (currentUser.role === 'freelancer') { %>
                <a href="/freelancer/edit-profile" class="btn btn-primary"><i class="fas fa-edit"></i> Edit Profile</a>
              <% } %>
            <% } else { %>
              <form action="/messages/start" method="POST" style="display:inline">
                <input type="hidden" name="userId" value="<%= profileUser._id %>">
                <button type="submit" class="btn btn-primary"><i class="fas fa-comment"></i> Message</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>

      <div class="profile-body">
        <div class="profile-stats-cards">
          <div class="pstat-card">
            <i class="fas fa-briefcase"></i>
            <div class="pstat-val"><%= profileUser.completedProjects || 0 %></div>
            <div class="pstat-label">Completed Projects</div>
          </div>
          <% if (profileUser.role === 'freelancer') { %>
          <div class="pstat-card">
            <i class="fas fa-rupee-sign"></i>
            <div class="pstat-val">₹<%= (profileUser.totalEarnings||0).toLocaleString('en-IN') %></div>
            <div class="pstat-label">Total Earned</div>
          </div>
          <div class="pstat-card">
            <i class="fas fa-clock"></i>
            <div class="pstat-val"><%= profileUser.hourlyRate ? '₹'+profileUser.hourlyRate+'/hr' : 'N/A' %></div>
            <div class="pstat-label">Hourly Rate</div>
          </div>
          <% } else { %>
          <div class="pstat-card">
            <i class="fas fa-rupee-sign"></i>
            <div class="pstat-val">₹<%= (profileUser.totalSpent||0).toLocaleString('en-IN') %></div>
            <div class="pstat-label">Total Spent</div>
          </div>
          <% } %>
          <div class="pstat-card">
            <i class="fas fa-calendar"></i>
            <div class="pstat-val"><%= new Date(profileUser.createdAt).toLocaleDateString('en-IN', {month:'short', year:'numeric'}) %></div>
            <div class="pstat-label">Member Since</div>
          </div>
        </div>

        <% if (profileUser.bio) { %>
        <div class="profile-section-card"><h3>About</h3><p><%= profileUser.bio %></p></div>
        <% } %>

        <% if (profileUser.role === 'freelancer' && (profileUser.skills||[]).length > 0) { %>
        <div class="profile-section-card">
          <h3>Skills</h3>
          <div class="tags-row tags-lg">
            <% profileUser.skills.forEach(sk => { %><span class="tag tag-lg"><%= sk %></span><% }) %>
          </div>
        </div>
        <% } %>

        <% if (projects.length > 0) { %>
        <div class="profile-section-card">
          <h3><%= profileUser.role === 'freelancer' ? 'Completed Work' : 'Posted Projects' %></h3>
          <div class="mini-projects-list">
            <% projects.forEach(p => { %>
            <div class="mini-project-item">
              <div class="fw-bold"><%= p.title %></div>
              <div class="text-muted small">₹<%= (p.budget||0).toLocaleString('en-IN') %> · <span class="badge status-<%= p.status %>"><%= p.status.replace('_',' ') %></span></div>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>

        <% if (profileUser.role === 'freelancer' && (profileUser.portfolio||[]).length > 0) { %>
        <div class="profile-section-card">
          <h3>Portfolio</h3>
          <div class="portfolio-grid">
            <% profileUser.portfolio.forEach(item => { %>
            <div class="portfolio-item">
              <h4><%= item.title %></h4>
              <p><%= item.description %></p>
              <% if (item.link) { %><a href="<%= item.link %>" target="_blank" class="btn btn-sm btn-outline">View Project</a><% } %>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>
      </div>
    </main>
  </div>
  <script src="/js/main.js"></script>
  <script src="/js/notifications.js"></script>
  <script src="/js/theme.js"></script>
  <script>const USER_ID = '<%= currentUser._id %>';</script>
</body>
</html>