<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="/socket.io/socket.io.js"></script>
  <style>
    /* ── Project info banner ── */
    .proj-banner {
      background: linear-gradient(135deg, #6c63ff 0%, #764ba2 100%);
      border-radius: var(--radius-md);
      padding: 18px 24px;
      color: #fff;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .proj-banner h2 { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
    .proj-banner p  { font-size: 0.84rem; opacity: 0.85; }
    .proj-banner .badge-white {
      background: rgba(255,255,255,0.2);
      color: #fff;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 600;
    }

    /* ── Filter bar ── */
    .date-filter {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 14px 18px;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .date-filter label { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); }
    .date-filter input[type="date"] {
      padding: 7px 10px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 0.85rem;
    }
    .date-filter input[type="date"]:focus { outline: none; border-color: var(--primary); }

    /* ── Summary strip ── */
    .report-summary {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 14px 20px;
      margin-bottom: 18px;
      font-size: 0.85rem;
      color: var(--text-secondary);
    }
    .report-summary strong { color: var(--text-primary); }

    /* ── Report card ── */
    .report-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      overflow: hidden;
      margin-bottom: 16px;
      transition: var(--transition);
    }
    .report-card:hover { box-shadow: var(--shadow-md); }
    .report-card.unread { border-left: 4px solid var(--primary); }

    .report-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 20px;
      background: var(--secondary);
      flex-wrap: wrap;
      gap: 10px;
    }
    .report-date {
      font-weight: 600;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .report-meta {
      display: flex;
      gap: 16px;
      font-size: 0.85rem;
      color: var(--text-secondary);
      align-items: center;
      flex-wrap: wrap;
    }
    .hours-badge {
      background: var(--primary-light);
      color: var(--primary);
      padding: 3px 10px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 0.82rem;
    }
    .progress-pill {
      background: var(--primary);
      color: #fff;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .unread-dot {
      width: 8px; height: 8px;
      background: var(--primary);
      border-radius: 50%;
      display: inline-block;
    }

    /* Progress bar */
    .report-progress-bar {
      height: 4px;
      background: var(--border);
    }
    .report-progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--primary), #764ba2);
      transition: width 0.5s ease;
    }

    /* Report body */
    .report-body {
      padding: 18px 20px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .report-section h4 {
      font-size: 0.88rem;
      font-weight: 600;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .report-task-list {
      padding-left: 18px;
      margin: 0;
    }
    .report-task-list li {
      font-size: 0.88rem;
      color: var(--text-secondary);
      padding: 3px 0;
    }
    .blocker-box {
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: var(--radius-sm);
      padding: 10px 14px;
      font-size: 0.88rem;
      color: #92400e;
    }
    .notes-box {
      background: var(--secondary);
      border-radius: var(--radius-sm);
      padding: 10px 14px;
      font-size: 0.88rem;
      color: var(--text-secondary);
    }

    /* Freelancer info strip */
    .reporter-strip {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 20px;
      border-top: 1px solid var(--border-light);
      background: var(--secondary);
      font-size: 0.82rem;
      color: var(--text-muted);
    }
    .reporter-strip img {
      width: 24px; height: 24px;
      border-radius: 50%;
      object-fit: cover;
    }

    /* Empty state */
    .empty-reports {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-muted);
    }
    .empty-reports i { font-size: 3rem; margin-bottom: 14px; display: block; color: var(--border); }
    .empty-reports h3 { margin-bottom: 6px; color: var(--text-secondary); }
  </style>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">

      <!-- Back link -->
      <div class="back-nav">
        <% if (currentUser.role === 'client') { %>
          <a href="/client/my-projects" class="back-link"><i class="fas fa-arrow-left"></i> Back to My Projects</a>
        <% } else if (currentUser.role === 'freelancer') { %>
          <a href="/freelancer/my-proposals" class="back-link"><i class="fas fa-arrow-left"></i> Back to My Proposals</a>
        <% } else { %>
          <a href="/admin/projects" class="back-link"><i class="fas fa-arrow-left"></i> Back to Projects</a>
        <% } %>
      </div>

      <!-- Project banner -->
      <div class="proj-banner">
        <div>
          <h2><i class="fas fa-clipboard-list"></i> &nbsp;<%= project.title %></h2>
          <p>
            Client: <strong><%= project.client?.name || 'N/A' %></strong>
            &nbsp;·&nbsp;
            Freelancer: <strong><%= project.hiredFreelancer?.name || 'N/A' %></strong>
          </p>
        </div>
        <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
          <span class="badge-white"><%= reports.length %> report<%= reports.length !== 1 ? 's' : '' %></span>
          <span class="badge-white status-<%= project.status %>" style="background:rgba(255,255,255,0.15)">
            <%= project.status.replace('_', ' ') %>
          </span>
          <% if (currentUser.role === 'freelancer') { %>
            <a href="/freelancer/submit-report?project=<%= project._id %>" class="btn btn-sm"
               style="background:#fff; color:var(--primary); font-weight:600">
              <i class="fas fa-plus"></i> New Report
            </a>
          <% } %>
        </div>
      </div>

      <!-- Date filter -->
      <form action="/reports/project/<%= project._id %>" method="GET" class="date-filter">
        <label><i class="fas fa-calendar"></i> From:</label>
        <input type="date" name="dateFrom" value="<%= filters.dateFrom || '' %>">
        <label>To:</label>
        <input type="date" name="dateTo" value="<%= filters.dateTo || '' %>">
        <select name="sort" style="padding:7px 10px; border:1.5px solid var(--border); border-radius:var(--radius-sm); font-size:0.85rem; background:#fff;">
          <option value="-date" <%= (filters.sort||'-date')==='-date' ? 'selected' : '' %>>Newest First</option>
          <option value="date"  <%= filters.sort==='date'  ? 'selected' : '' %>>Oldest First</option>
        </select>
        <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search"></i> Filter</button>
        <a href="/reports/project/<%= project._id %>" class="btn btn-sm btn-outline">Clear</a>
      </form>

      <!-- Summary strip -->
      <% if (reports.length > 0) { %>
      <div class="report-summary">
        <span><i class="fas fa-file-alt"></i> <strong><%= reports.length %></strong> reports</span>
        <span><i class="fas fa-clock"></i> Total hours: <strong><%= reports.reduce((s,r) => s + (r.hoursWorked||0), 0).toFixed(1) %></strong></span>
        <span><i class="fas fa-chart-line"></i> Latest progress: <strong><%= reports[0]?.progressPercentage || 0 %>%</strong></span>
        <% if (currentUser.role === 'client') { %>
          <span style="margin-left:auto; color:var(--primary)">
            <i class="fas fa-eye"></i> Viewing as client
          </span>
        <% } %>
      </div>
      <% } %>

      <!-- Reports list -->
      <% if (reports.length === 0) { %>
        <div class="empty-reports">
          <i class="fas fa-clipboard"></i>
          <h3>No reports yet</h3>
          <p>
            <% if (currentUser.role === 'freelancer') { %>
              Submit your first daily report to keep the client updated.
              <br><br>
              <a href="/freelancer/submit-report?project=<%= project._id %>" class="btn btn-primary">
                <i class="fas fa-plus"></i> Submit Report
              </a>
            <% } else { %>
              The freelancer hasn't submitted any reports for this project yet.
            <% } %>
          </p>
        </div>
      <% } %>

      <% reports.forEach(r => { %>
      <div class="report-card <%= (isClient && !r.clientSeen) ? 'unread' : '' %>">

        <div class="report-header">
          <div class="report-date">
            <% if (isClient && !r.clientSeen) { %>
              <span class="unread-dot" title="New"></span>
            <% } %>
            <i class="fas fa-calendar-day" style="color:var(--primary)"></i>
            <%= new Date(r.date).toLocaleDateString('en-IN', {
              weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
            }) %>
          </div>
          <div class="report-meta">
            <span class="hours-badge"><i class="fas fa-clock"></i> <%= r.hoursWorked %> hrs</span>
            <span class="progress-pill"><%= r.progressPercentage || 0 %>% complete</span>
            <span style="font-size:0.78rem; color:var(--text-muted)">
              Submitted <%= new Date(r.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'}) %>
            </span>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="report-progress-bar">
          <div class="report-progress-fill" style="width:<%= r.progressPercentage || 0 %>%"></div>
        </div>

        <div class="report-body">

          <!-- Tasks completed -->
          <% if (r.tasksCompleted && r.tasksCompleted.length > 0) { %>
          <div class="report-section">
            <h4>
              <i class="fas fa-check-circle" style="color:var(--success)"></i>
              Tasks Completed
              <span style="background:var(--success);color:#fff;padding:1px 7px;border-radius:20px;font-size:0.72rem;font-weight:600;margin-left:4px"><%= r.tasksCompleted.length %></span>
            </h4>
            <ul class="report-task-list">
              <% r.tasksCompleted.forEach(t => { %>
                <li><%= t %></li>
              <% }) %>
            </ul>
          </div>
          <% } %>

          <!-- Tasks planned -->
          <% if (r.tasksPlanned && r.tasksPlanned.length > 0) { %>
          <div class="report-section">
            <h4>
              <i class="fas fa-calendar-check" style="color:var(--info)"></i>
              Planned for Tomorrow
              <span style="background:var(--info);color:#fff;padding:1px 7px;border-radius:20px;font-size:0.72rem;font-weight:600;margin-left:4px"><%= r.tasksPlanned.length %></span>
            </h4>
            <ul class="report-task-list">
              <% r.tasksPlanned.forEach(t => { %>
                <li><%= t %></li>
              <% }) %>
            </ul>
          </div>
          <% } %>

          <!-- Blockers -->
          <% if (r.blockers && r.blockers.trim()) { %>
          <div class="report-section">
            <h4><i class="fas fa-exclamation-triangle" style="color:var(--warning)"></i> Blockers / Issues</h4>
            <div class="blocker-box"><%= r.blockers %></div>
          </div>
          <% } %>

          <!-- Notes -->
          <% if (r.notes && r.notes.trim()) { %>
          <div class="report-section">
            <h4><i class="fas fa-sticky-note" style="color:var(--text-muted)"></i> Notes</h4>
            <div class="notes-box"><%= r.notes %></div>
          </div>
          <% } %>

        </div>

        <!-- Freelancer info strip (visible to client/admin) -->
        <% if (isClient || isAdmin) { %>
        <div class="reporter-strip">
          <img src="<%= r.freelancer?.googleAvatar || '/avatar/' + r.freelancer?._id %>"
               onerror="this.src='/images/default-avatar.png'" alt="">
          <span>Submitted by <strong><%= r.freelancer?.name || 'Freelancer' %></strong></span>
          <span style="margin-left:auto">
            <i class="fas fa-calendar"></i>
            <%= new Date(r.createdAt).toLocaleDateString('en-IN') %>
          </span>
          <% if (isClient && r.clientSeen) { %>
            <span style="color:var(--success); font-size:0.78rem">
              <i class="fas fa-eye"></i> Seen
            </span>
          <% } %>
        </div>
        <% } %>

      </div>
      <% }) %>

    </main>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/notifications.js"></script>
  <script>const USER_ID = '<%= currentUser._id %>';</script>
</body>
</html>
