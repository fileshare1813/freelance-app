<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <div><h1 class="page-title">Notifications</h1></div>
        <button onclick="markAllReadPage()" class="btn btn-outline"><i class="fas fa-check-double"></i> Mark All Read</button>
      </div>
      <div class="notif-page-list">
        <% if (notifications.length === 0) { %>
          <div class="empty-state-box"><i class="fas fa-bell-slash fa-3x"></i><h3>No notifications</h3><p>You're all caught up!</p></div>
        <% } %>
        <% notifications.forEach(n => { %>
        <div class="notif-page-item <%= !n.read ? 'notif-unread' : '' %>" id="notif-<%= n._id %>">
          <div class="notif-page-icon notif-icon-<%= n.type %>">
            <% const icons = {message:'fas fa-comment',proposal:'fas fa-paper-plane',hired:'fas fa-handshake',project_update:'fas fa-briefcase',report:'fas fa-file-alt',review:'fas fa-star',payment:'fas fa-rupee-sign',system:'fas fa-info-circle'} %>
            <i class="<%= icons[n.type] || 'fas fa-bell' %>"></i>
          </div>
          <div class="notif-page-body">
            <div class="notif-page-sender">
              <% if (n.sender) { %>
                <img src="<%= n.sender.googleAvatar || '/avatar/'+n.sender._id %>" class="notif-sender-avatar" onerror="this.src='/images/default-avatar.png'">
                <strong><%= n.sender.name %></strong>
              <% } else { %><strong>FreelanceHub</strong><% } %>
            </div>
            <div class="notif-page-msg"><%= n.message %></div>
            <div class="notif-page-time"><%= new Date(n.createdAt).toLocaleString('en-IN') %></div>
          </div>
          <div class="notif-page-actions">
            <% if (!n.read) { %>
              <button onclick="markRead('<%= n._id %>')" class="btn btn-sm btn-outline"><i class="fas fa-check"></i></button>
            <% } %>
            <% if (n.link) { %>
              <a href="<%= n.link %>" class="btn btn-sm btn-primary"><i class="fas fa-arrow-right"></i> View</a>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </main>
  </div>
  <script src="/js/main.js"></script>
  <script src="/js/notifications.js"></script>
  <script>
    const USER_ID = '<%= currentUser._id %>';
    async function markRead(id) {
      await fetch('/notifications/mark-read/'+id, {method:'POST'});
      document.getElementById('notif-'+id)?.classList.remove('notif-unread');
    }
    async function markAllReadPage() {
      await fetch('/notifications/mark-all-read', {method:'POST'});
      document.querySelectorAll('.notif-unread').forEach(el => el.classList.remove('notif-unread'));
    }
  </script>
</body>
</html>