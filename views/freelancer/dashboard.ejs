<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1 class="page-title">Welcome, <%= currentUser.name.split(' ')[0] %>! 🚀</h1>
          <p class="page-subtitle">Your freelance workspace</p>
        </div>
        <div class="header-actions">
          <a href="/freelancer/browse-projects" class="btn btn-primary"><i class="fas fa-search"></i> Find Projects</a>
          <span class="live-badge"><span class="live-dot"></span> Live</span>
        </div>
      </div>
      <div class="stats-grid">
        <div class="stat-card stat-blue">
          <div class="stat-icon"><i class="fas fa-laptop-code"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.activeProjects %></div><div class="stat-label">Active Projects</div></div>
        </div>
        <div class="stat-card stat-green">
          <div class="stat-icon"><i class="fas fa-rupee-sign"></i></div>
          <div class="stat-info"><div class="stat-value">₹<%= (stats.totalEarnings||0).toLocaleString('en-IN') %></div><div class="stat-label">Total Earned</div></div>
        </div>
        <div class="stat-card stat-purple">
          <div class="stat-icon"><i class="fas fa-paper-plane"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.totalProposals %></div><div class="stat-label">Total Proposals</div></div>
        </div>
        <div class="stat-card stat-orange">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.completedProjects %></div><div class="stat-label">Completed</div></div>
        </div>
      </div>
      <div class="charts-grid">
        <div class="chart-card chart-wide">
          <div class="chart-header"><h3>Earnings Trend</h3><span class="chart-badge">Last 6 months</span></div>
          <canvas id="revenueChart" height="100"></canvas>
        </div>
        <div class="chart-card">
          <div class="chart-header"><h3>Projects Won</h3><span class="chart-badge">Accepted proposals</span></div>
          <canvas id="projectChart" height="100"></canvas>
        </div>
      </div>
      <div class="table-card">
        <div class="table-header">
          <h3>Recent Proposals</h3>
          <a href="/freelancer/my-proposals" class="view-all">View all →</a>
        </div>
        <% if (recentProposals.length === 0) { %>
          <div class="empty-state-box">
            <i class="fas fa-paper-plane fa-2x"></i>
            <p>No proposals yet. <a href="/freelancer/browse-projects">Browse projects</a> to get started!</p>
          </div>
        <% } else { %>
        <table class="data-table">
          <thead><tr><th>Project</th><th>Your Bid</th><th>Delivery</th><th>Status</th><th>Applied</th></tr></thead>
          <tbody>
            <% recentProposals.forEach(p => { %>
            <tr>
              <td class="fw-bold"><%= p.project?.title?.substring(0,35) || 'N/A' %></td>
              <td>₹<%= (p.bidAmount||0).toLocaleString('en-IN') %></td>
              <td><%= p.deliveryTime %> days</td>
              <td><span class="badge status-<%= p.status %>"><%= p.status %></span></td>
              <td><%= new Date(p.createdAt).toLocaleDateString('en-IN') %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
      <% if (stats.activeProjects > 0) { %>
      <div class="quick-action-card">
        <h3><i class="fas fa-file-alt"></i> Submit Today's Report</h3>
        <p>Keep your clients updated with daily progress reports</p>
        <a href="/freelancer/submit-report" class="btn btn-primary">Submit Report</a>
      </div>
      <% } %>
    </main>
  </div>
  <script>
    const GRAPH_DATA = <%- JSON.stringify(graphData) %>;
    const USER_ID = '<%= currentUser._id %>';
    const USER_ROLE = 'freelancer';
    const GRAPH_API_URL = '/freelancer/graph-data';
  </script>
  <script src="/js/main.js"></script>
  <script src="/js/charts.js"></script>
  <script src="/js/notifications.js"></script>
</body>
</html>