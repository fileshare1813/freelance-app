<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <div>
          <h1 class="page-title">Welcome, <%= currentUser.name.split(' ')[0] %>! 👋</h1>
          <p class="page-subtitle">Here's your project overview</p>
        </div>
        <div class="header-actions">
          <a href="/client/post-project" class="btn btn-primary"><i class="fas fa-plus"></i> Post Project</a>
          <span class="live-badge"><span class="live-dot"></span> Live</span>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card stat-blue">
          <div class="stat-icon"><i class="fas fa-folder-open"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.activeProjects %></div>
            <div class="stat-label">Active Projects</div>
          </div>
        </div>
        <div class="stat-card stat-green">
          <div class="stat-icon"><i class="fas fa-check-double"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.completedProjects %></div>
            <div class="stat-label">Completed</div>
          </div>
        </div>
        <div class="stat-card stat-purple">
          <div class="stat-icon"><i class="fas fa-rupee-sign"></i></div>
          <div class="stat-info">
            <div class="stat-value">₹<%= (stats.totalSpent || 0).toLocaleString('en-IN') %></div>
            <div class="stat-label">Total Spent</div>
          </div>
        </div>
        <div class="stat-card stat-orange">
          <div class="stat-icon"><i class="fas fa-paper-plane"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.totalProposals %></div>
            <div class="stat-label">Proposals Received</div>
          </div>
        </div>
      </div>

      <div class="charts-grid">
        <div class="chart-card chart-wide">
          <div class="chart-header">
            <h3>Project Activity</h3>
            <span class="chart-badge">Last 6 months</span>
          </div>
          <canvas id="projectChart" height="100"></canvas>
        </div>
        <div class="chart-card">
          <div class="chart-header">
            <h3>Spending Trend</h3>
            <span class="chart-badge">₹ spent</span>
          </div>
          <canvas id="revenueChart" height="100"></canvas>
        </div>
      </div>

      <div class="table-card">
        <div class="table-header">
          <h3>Recent Projects</h3>
          <a href="/client/my-projects" class="view-all">View all →</a>
        </div>
        <% if (recentProjects.length === 0) { %>
          <div class="empty-state-box">
            <i class="fas fa-folder-open"></i>
            <p>No projects yet. <a href="/client/post-project">Post your first project!</a></p>
          </div>
        <% } else { %>
        <table class="data-table">
          <thead><tr><th>Title</th><th>Budget</th><th>Status</th><th>Proposals</th><th>Posted</th><th>Actions</th></tr></thead>
          <tbody>
            <% recentProjects.forEach(p => { %>
            <tr>
              <td class="fw-bold"><%= p.title.substring(0,35) %><%= p.title.length > 35 ? '...' : '' %></td>
              <td>₹<%= (p.budget || 0).toLocaleString('en-IN') %></td>
              <td><span class="badge status-<%= p.status %>"><%= p.status.replace('_',' ') %></span></td>
              <td><%= p.proposalCount || 0 %></td>
              <td><%= new Date(p.createdAt).toLocaleDateString('en-IN') %></td>
              <td>
                <a href="/client/my-projects/<%= p._id %>/proposals" class="btn btn-sm btn-outline">
                  <i class="fas fa-users"></i> Proposals
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </main>
  </div>
  <script>
    const GRAPH_DATA = <%- JSON.stringify(graphData) %>;
    const USER_ID = '<%= currentUser._id %>';
    const USER_ROLE = 'client';
    const GRAPH_API_URL = '/client/graph-data';
  </script>
  <script src="/js/main.js"></script>
  <script src="/js/charts.js"></script>
  <script src="/js/notifications.js"></script>
</body>
</html>