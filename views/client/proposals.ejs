<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <div>
          <a href="/client/my-projects" class="back-link"><i class="fas fa-arrow-left"></i> Back</a>
          <h1 class="page-title"><%= project.title %></h1>
          <p class="page-subtitle">Budget: ₹<%= (project.budget||0).toLocaleString('en-IN') %> · <%= proposals.length %> proposals</p>
        </div>
      </div>
      <% if (proposals.length === 0) { %>
        <div class="empty-state-box"><i class="fas fa-inbox fa-3x"></i><h3>No proposals yet</h3><p>Freelancers haven't applied yet. Share your project!</p></div>
      <% } %>
      <div class="proposals-list">
        <% proposals.forEach(prop => { %>
        <div class="proposal-card <%= prop.status === 'accepted' ? 'proposal-accepted' : '' %>">
          <div class="proposal-header">
            <div class="proposer-info">
              <img src="<%= prop.freelancer.googleAvatar || '/avatar/' + prop.freelancer._id %>"
                class="proposal-avatar" onerror="this.src='/images/default-avatar.png'">
              <div>
                <h4><a href="/client/freelancer/<%= prop.freelancer._id %>"><%= prop.freelancer.name %></a></h4>
                <div class="rating-row">
                  <% for(let i=1;i<=5;i++) { %><i class="fas fa-star <%= i <= Math.round(prop.freelancer.rating||0) ? 'star-filled' : 'star-empty' %>"></i><% } %>
                  <span>(<%= prop.freelancer.reviewCount || 0 %> reviews)</span>
                </div>
                <div class="tags-row">
                  <% (prop.freelancer.skills||[]).slice(0,4).forEach(sk => { %><span class="tag"><%= sk %></span><% }) %>
                </div>
              </div>
            </div>
            <div class="proposal-bid">
              <div class="bid-amount">₹<%= (prop.bidAmount||0).toLocaleString('en-IN') %></div>
              <div class="delivery-time"><i class="fas fa-clock"></i> <%= prop.deliveryTime %> days</div>
              <span class="badge status-<%= prop.status %>"><%= prop.status %></span>
            </div>
          </div>
          <div class="proposal-letter">
            <h5>Cover Letter:</h5>
            <p><%= prop.coverLetter %></p>
          </div>
          <div class="proposal-actions">
            <a href="/client/freelancer/<%= prop.freelancer._id %>" class="btn btn-sm btn-outline">
              <i class="fas fa-user"></i> View Profile
            </a>
            <% if (project.status === 'open' && prop.status === 'pending') { %>
              <form action="/client/proposals/<%= prop._id %>/accept" method="POST" style="display:inline">
                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Hire this freelancer?')">
                  <i class="fas fa-check"></i> Accept & Hire
                </button>
              </form>
            <% } %>
            <form action="/messages/start" method="POST" style="display:inline">
              <input type="hidden" name="userId" value="<%= prop.freelancer._id %>">
              <input type="hidden" name="projectId" value="<%= project._id %>">
              <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-comment"></i> Message</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
    </main>
  </div>
  <script src="/js/main.js"></script>
  <script src="/js/notifications.js"></script>
  <script src="/js/theme.js"></script>
  <script>const USER_ID = '<%= currentUser._id %>';</script>
</body>
</html>