<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="/socket.io/socket.io.js"></script>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
      <div class="page-header">
        <div><h1 class="page-title">Post a Project</h1><p class="page-subtitle">Find the perfect freelancer for your work</p></div>
      </div>
      <div class="form-card">
        <form action="/client/post-project" method="POST" class="project-form">
          <div class="form-section">
            <h3><i class="fas fa-info-circle"></i> Project Details</h3>
            <div class="form-group">
              <label>Project Title *</label>
              <input type="text" name="title" class="form-input" placeholder="e.g. Build a React E-commerce Website" required maxlength="100">
            </div>
            <div class="form-group">
              <label>Description *</label>
              <textarea name="description" class="form-textarea" rows="6" placeholder="Describe your project in detail — what you need, deliverables, and any specific requirements..." required minlength="50"></textarea>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Category *</label>
                <select name="category" class="form-select" required>
                  <option value="">Select category</option>
                  <option>Web Development</option>
                  <option>Mobile Development</option>
                  <option>UI/UX Design</option>
                  <option>Graphic Design</option>
                  <option>Content Writing</option>
                  <option>Digital Marketing</option>
                  <option>Data Science</option>
                  <option>Video Editing</option>
                  <option>DevOps</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label>Priority</label>
                <select name="priority" class="form-select">
                  <option value="low">Low</option>
                  <option value="medium" selected>Medium</option>
                  <option value="high">High</option>
                </select>
              </div>
            </div>
          </div>

          <div class="form-section">
            <h3><i class="fas fa-rupee-sign"></i> Budget & Timeline</h3>
            <div class="form-row">
              <div class="form-group">
                <label>Budget (₹) *</label>
                <input type="number" name="budget" class="form-input" placeholder="e.g. 15000" required min="100">
              </div>
              <div class="form-group">
                <label>Budget Type</label>
                <select name="budgetType" class="form-select">
                  <option value="fixed">Fixed Price</option>
                  <option value="hourly">Hourly Rate</option>
                </select>
              </div>
              <div class="form-group">
                <label>Deadline</label>
                <input type="date" name="deadline" class="form-input" min="<%= new Date().toISOString().split('T')[0] %>">
              </div>
            </div>
          </div>

          <div class="form-section">
            <h3><i class="fas fa-tags"></i> Skills Required</h3>
            <div class="form-group">
              <label>Skills (comma-separated)</label>
              <input type="text" name="skills" class="form-input" id="skillsInput" placeholder="e.g. React, Node.js, MongoDB, CSS">
              <div class="skill-suggestions">
                <% ['JavaScript','Python','React','Node.js','MongoDB','PHP','Laravel','Flutter','Django','Vue.js','Docker','AWS'].forEach(s => { %>
                  <span class="skill-chip" onclick="addSkill('<%= s %>')"><%= s %></span>
                <% }) %>
              </div>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-lg">
              <i class="fas fa-paper-plane"></i> Post Project
            </button>
            <a href="/client/my-projects" class="btn btn-outline btn-lg">Cancel</a>
          </div>
        </form>
      </div>
    </main>
  </div>
  <script src="/js/main.js"></script>
  <script src="/js/notifications.js"></script>
  <script src="/js/theme.js"></script>
  <script>
    const USER_ID = '<%= currentUser._id %>';
    function addSkill(skill) {
      const input = document.getElementById('skillsInput');
      const current = input.value.trim();
      const skills = current ? current.split(',').map(s => s.trim()) : [];
      if (!skills.includes(skill)) { skills.push(skill); input.value = skills.join(', '); }
    }
  </script>
</body>
</html>