<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script src="/socket.io/socket.io.js"></script>
  <style>
    /* ── Summary cards ── */
    .sum-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:16px; margin-bottom:24px; }

    /* ── Payment row cards ── */
    .prow{ background:#fff; border:1px solid var(--border); border-radius:var(--radius-md); overflow:hidden; margin-bottom:14px; }
    .prow-head{ display:flex; justify-content:space-between; align-items:flex-start; padding:14px 18px; background:var(--secondary); flex-wrap:wrap; gap:10px; }
    .prow-body{ padding:14px 18px; }
    .prow-actions{ display:flex; gap:8px; margin-top:12px; flex-wrap:wrap; align-items:center; }

    /* Payout details box */
    .payout-box{
      background:#f8fafc; border:1px solid var(--border);
      border-radius:var(--radius-sm); padding:12px 14px; margin-top:10px;
    }
    .payout-box h5{ font-size:.78rem; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.04em; margin-bottom:8px; }
    .pd-row{ display:flex; gap:8px; margin-bottom:4px; font-size:.83rem; }
    .pd-key{ color:var(--text-muted); min-width:110px; flex-shrink:0; }
    .pd-val{ font-weight:600; word-break:break-all; }

    /* No payout warning */
    .no-payout{ background:#fffbeb; border:1px solid #fde68a; border-radius:var(--radius-sm); padding:10px 14px; font-size:.83rem; color:#92400e; margin-top:10px; }

    /* Status chips */
    .chip{ display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:.75rem; font-weight:600; }
    .chip-pending{ background:#fef3c7; color:#d97706; }
    .chip-paid{ background:#dbeafe; color:#2563eb; }
    .chip-released{ background:#ede9ff; color:#6c63ff; }
    .chip-completed{ background:#dcfce7; color:#16a34a; }
    .chip-failed{ background:#fee2e2; color:#dc2626; }

    /* Modal */
    .modal-overlay{ position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:500; display:flex; align-items:center; justify-content:center; padding:20px; }
    .modal{ background:#fff; border-radius:var(--radius-lg); padding:24px; width:100%; max-width:460px; box-shadow:var(--shadow-lg); }
    .modal h3{ font-size:1rem; font-weight:700; margin-bottom:12px; display:flex; align-items:center; gap:8px; }
    .modal p{ color:var(--text-secondary); font-size:.88rem; margin-bottom:16px; }
    .modal-actions{ display:flex; gap:10px; margin-top:16px; }

    /* Razorpay transfer guide box */
    .rzp-guide{
      background:#ede9ff; border:1px solid #c4b5fd;
      border-radius:var(--radius-sm); padding:12px 14px; margin-bottom:14px; font-size:.83rem; color:#5b21b6;
    }
    .rzp-guide h5{ font-weight:700; margin-bottom:6px; }
    .rzp-guide ol{ padding-left:16px; }
    .rzp-guide li{ margin-bottom:3px; }
  </style>
</head>
<body class="app-body">
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">

      <div class="page-header">
        <div><h1 class="page-title">Payment Management</h1><p class="page-subtitle">Track all transactions · release payouts to freelancers</p></div>
      </div>

      <!-- ── Summary stats ── -->
      <div class="sum-grid">
        <div class="stat-card stat-green">
          <div class="stat-icon"><i class="fas fa-rupee-sign"></i></div>
          <div class="stat-info">
            <div class="stat-value">₹<%= (summary.totalCollected||0).toLocaleString('en-IN') %></div>
            <div class="stat-label">Total Collected</div>
          </div>
        </div>
        <div class="stat-card stat-purple">
          <div class="stat-icon"><i class="fas fa-percent"></i></div>
          <div class="stat-info">
            <div class="stat-value">₹<%= (summary.totalFees||0).toLocaleString('en-IN') %></div>
            <div class="stat-label">Platform Revenue (10%)</div>
          </div>
        </div>
        <div class="stat-card stat-blue">
          <div class="stat-icon"><i class="fas fa-clock"></i></div>
          <div class="stat-info">
            <div class="stat-value">₹<%= (summary.pendingPayout||0).toLocaleString('en-IN') %></div>
            <div class="stat-label">Pending Payout</div>
          </div>
        </div>
        <div class="stat-card stat-orange">
          <div class="stat-icon"><i class="fas fa-check-double"></i></div>
          <div class="stat-info">
            <div class="stat-value">₹<%= (summary.totalPaid||0).toLocaleString('en-IN') %></div>
            <div class="stat-label">Paid to Freelancers</div>
          </div>
        </div>
      </div>

      <!-- ── Filters ── -->
      <div class="filter-bar">
        <form action="/admin/payments" method="GET" class="filter-form">
          <select name="status" class="filter-select" onchange="this.form.submit()">
            <option value="">All Status</option>
            <% ['pending','paid','released','completed','failed'].forEach(s=>{ %>
              <option value="<%= s %>" <%= filters.status===s?'selected':'' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
            <% }) %>
          </select>
          <a href="/admin/payments" class="btn btn-outline">Clear</a>
        </form>
      </div>

      <!-- ── Payment rows ── -->
      <% if(payments.length===0){ %>
        <div class="empty-state-box"><i class="fas fa-wallet fa-3x"></i><h3>No payments found</h3></div>
      <% } %>

      <% const chipMap={pending:'chip-pending',paid:'chip-paid',released:'chip-released',completed:'chip-completed',failed:'chip-failed'}; %>

      <% payments.forEach(pay=>{ %>
      <div class="prow" id="prow_<%= pay._id %>">
        <div class="prow-head">
          <div>
            <div class="fw-bold" style="font-size:1rem"><%= pay.project?.title||'N/A' %></div>
            <div class="text-muted small" style="margin-top:2px">
              Client: <strong><%= pay.client?.name %></strong>
              &nbsp;→&nbsp;
              Freelancer: <strong><%= pay.freelancer?.name %></strong>
            </div>
            <div class="text-muted small"><%= new Date(pay.createdAt).toLocaleString('en-IN') %></div>
          </div>
          <div style="text-align:right">
            <div style="font-size:1.3rem;font-weight:800;color:var(--primary)">₹<%= pay.totalAmount?.toLocaleString('en-IN') %></div>
            <span class="chip <%= chipMap[pay.status]||'chip-pending' %>"><%= pay.status %></span>
            <span class="badge <%= pay.razorpayMode==='live'?'badge-success':'badge-warning' %>" style="margin-left:4px"><%= (pay.razorpayMode||'test').toUpperCase() %></span>
          </div>
        </div>

        <div class="prow-body">
          <!-- Amounts breakdown -->
          <div style="display:flex;gap:20px;flex-wrap:wrap;font-size:.84rem;margin-bottom:10px">
            <span><i class="fas fa-hand-holding-usd" style="color:var(--success)"></i> Freelancer: <strong>₹<%= pay.freelancerAmount?.toLocaleString('en-IN') %></strong></span>
            <span><i class="fas fa-percent" style="color:var(--primary)"></i> Platform fee: <strong>₹<%= pay.platformFee?.toLocaleString('en-IN') %></strong></span>
            <% if(pay.razorpayPaymentId){ %><span><i class="fas fa-fingerprint"></i> Rzp: <code style="font-size:.78rem"><%= pay.razorpayPaymentId %></code></span><% } %>
            <% if(pay.releasedBy){ %><span><i class="fas fa-user-check"></i> Released by: <%= pay.releasedBy?.name %></span><% } %>
          </div>

          <!-- Freelancer payout details -->
          <% const pd = pay.payoutSnapshot || pay.freelancer?.payoutDetails; %>
          <% if(pd?.method){ %>
          <div class="payout-box">
            <h5><i class="fas fa-<%= pd.method==='upi'?'mobile-alt':'university' %>"></i> Freelancer Payout Details</h5>
            <% if(pd.method==='upi'){ %>
              <div class="pd-row"><span class="pd-key">Method:</span><span class="pd-val">UPI</span></div>
              <div class="pd-row"><span class="pd-key">UPI ID:</span><span class="pd-val"><%= pd.upiId %></span></div>
            <% } else { %>
              <div class="pd-row"><span class="pd-key">Method:</span><span class="pd-val">Bank Transfer</span></div>
              <div class="pd-row"><span class="pd-key">Account Name:</span><span class="pd-val"><%= pd.accountName %></span></div>
              <div class="pd-row"><span class="pd-key">Account No:</span><span class="pd-val"><%= pd.accountNumber %></span></div>
              <div class="pd-row"><span class="pd-key">IFSC:</span><span class="pd-val"><%= pd.ifsc %></span></div>
              <% if(pd.bankName){ %><div class="pd-row"><span class="pd-key">Bank:</span><span class="pd-val"><%= pd.bankName %></span></div><% } %>
            <% } %>
          </div>
          <% } else if(pay.status==='paid'){ %>
          <div class="no-payout">
            <i class="fas fa-exclamation-triangle"></i>
            Freelancer (<strong><%= pay.freelancer?.name %></strong>) hasn't added payout details yet. They will be prompted to add bank/UPI before you release.
          </div>
          <% } %>

          <!-- Admin note -->
          <% if(pay.adminNote){ %>
          <div style="font-size:.82rem;color:var(--text-muted);margin-top:8px">
            <i class="fas fa-sticky-note"></i> Admin note: <%= pay.adminNote %>
          </div>
          <% } %>

          <!-- Actions -->
          <div class="prow-actions">
            <% if(pay.status==='paid'){ %>
              <% if(pd?.method){ %>
                <button class="btn btn-sm btn-primary" onclick="openReleaseModal('<%= pay._id %>','<%= pay.freelancerAmount?.toLocaleString("en-IN") %>','<%= pay.freelancer?.name %>','<%= pd.method %>','<%= pd.method==="upi"?pd.upiId:(pd.accountName+" · ****"+pd.accountNumber?.slice(-4)) %>')">
                  <i class="fas fa-paper-plane"></i> Release Payment
                </button>
              <% } else { %>
                <button class="btn btn-sm btn-outline" disabled title="Waiting for freelancer to add payout details">
                  <i class="fas fa-clock"></i> Waiting for Payout Details
                </button>
              <% } %>
            <% } %>

            <% if(pay.status==='released'){ %>
              <button class="btn btn-sm btn-success" onclick="confirmComplete('<%= pay._id %>')">
                <i class="fas fa-check-double"></i> Mark as Sent
              </button>
              <span style="font-size:.8rem;color:var(--text-muted)">
                <i class="fas fa-info-circle"></i> Click after you transfer in Razorpay dashboard
              </span>
            <% } %>
          </div>

        </div>
      </div>
      <% }) %>

    </main>
  </div>

  <!-- ── Release Modal ── -->
  <div class="modal-overlay" id="releaseModal" style="display:none">
    <div class="modal">
      <h3><i class="fas fa-paper-plane"></i> Release Payment to Freelancer</h3>

      <!-- Razorpay transfer guide -->
      <div class="rzp-guide">
        <h5><i class="fas fa-info-circle"></i> Steps to transfer via Razorpay Dashboard</h5>
        <ol>
          <li>Go to <strong>razorpay.com/dashboard</strong> → Payouts</li>
          <li>Click <strong>"Create Payout"</strong></li>
          <li>Enter freelancer's <span id="modalPayoutMethod"></span> shown below</li>
          <li>Amount: <strong>₹<span id="modalAmount"></span></strong> (90% of total)</li>
          <li>Complete transfer, then click <strong>"Release"</strong> below</li>
        </ol>
      </div>

      <div style="background:#f8fafc;border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 14px;margin-bottom:14px;font-size:.85rem">
        <div><strong>Freelancer:</strong> <span id="modalFreelancer"></span></div>
        <div style="margin-top:4px"><strong>Payout to:</strong> <span id="modalPayoutDetail"></span></div>
        <div style="margin-top:4px"><strong>Amount:</strong> <strong style="color:var(--primary)">₹<span id="modalAmount2"></span></strong></div>
      </div>

      <div class="form-group">
        <label>Admin Note (optional)</label>
        <input type="text" class="form-input" id="adminNote" placeholder="e.g. Transferred via UPI on 15 Jan · UTR: 1234567890">
      </div>

      <p style="font-size:.8rem;color:var(--text-muted)">
        <i class="fas fa-exclamation-triangle" style="color:var(--warning)"></i>
        Only click Release after you have actually transferred the money in Razorpay dashboard.
      </p>

      <div class="modal-actions">
        <button class="btn btn-primary" onclick="confirmRelease()"><i class="fas fa-check"></i> I've Transferred · Release</button>
        <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/notifications.js"></script>
  <script>
    const USER_ID = '<%= currentUser._id %>';
    let activePaymentId = null;

    function openReleaseModal(id, amount, freelancer, method, payoutDetail) {
      activePaymentId = id;
      document.getElementById('modalAmount').textContent     = amount;
      document.getElementById('modalAmount2').textContent    = amount;
      document.getElementById('modalFreelancer').textContent = freelancer;
      document.getElementById('modalPayoutMethod').textContent = method.toUpperCase();
      document.getElementById('modalPayoutDetail').textContent = payoutDetail;
      document.getElementById('adminNote').value = '';
      document.getElementById('releaseModal').style.display = 'flex';
    }

    function closeModal() {
      document.getElementById('releaseModal').style.display = 'none';
      activePaymentId = null;
    }

    async function confirmRelease() {
      if (!activePaymentId) return;
      const note = document.getElementById('adminNote').value.trim();

      try {
        const r = await fetch(`/admin/payments/${activePaymentId}/release`, {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ note })
        });
        const d = await r.json();
        if (d.success) {
          closeModal();
          showToast(d.message, 'success');
          setTimeout(() => location.reload(), 1500);
        } else {
          alert(d.message || 'Failed to release');
        }
      } catch(e) { alert('Network error. Try again.'); }
    }

    async function confirmComplete(id) {
      if (!confirm('Confirm you have sent the money to the freelancer?')) return;
      try {
        const r = await fetch(`/admin/payments/${id}/complete`, {
          method:'POST', headers:{'Content-Type':'application/json'}
        });
        const d = await r.json();
        if (d.success) {
          showToast(d.message, 'success');
          setTimeout(() => location.reload(), 1500);
        } else {
          alert(d.message || 'Failed');
        }
      } catch(e) { alert('Network error. Try again.'); }
    }

    function showToast(msg, type) {
      const t = document.createElement('div');
      t.className = `flash flash-${type==='success'?'success':'error'}`;
      t.style.cssText = 'position:fixed;top:80px;right:16px;z-index:9999;min-width:280px';
      t.innerHTML = `<i class="fas fa-${type==='success'?'check-circle':'exclamation-circle'}"></i> ${msg}`;
      document.body.appendChild(t);
      setTimeout(() => t.remove(), 3500);
    }

    // Close modal on overlay click
    document.getElementById('releaseModal').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });
  </script>
</body>
</html>
